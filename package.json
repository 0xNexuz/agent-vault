{
  "name": "agent-vault",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "test": "node --test scripts/*.test.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "compile:vault": "node -e \"process.env.COMPILE_ONLY='1'; import('./scripts/deploy-vault.mjs')\"",
